if theme.menu
  #sidebar
    #menu-mask
    #sidebar-menus
      .add-menu-container 
        if theme.nav.right_items
          each item in theme.nav.right_items
            div(id=item.id)
              a(class=item.class || 'site-page', href=item.raw_link ? item.link : url_for(item.link), title=item.title)
                i(class=item.icon)
      .is-center#sidebar-avatar
        .avatar-img.is-center
          if theme.aside.card_author.mood_icon
            img.mood-icon(src=url_for(theme.aside.card_author.mood_icon) alt="mood" onerror=`this.onerror=null;this.src='` + url_for(theme.error_img.flink) + `'`)
          img(src=url_for(theme.avatar.img) onerror=`this.onerror=null;this.src='` + url_for(theme.error_img.flink) + `'` alt="avatar")
        .author-info__name= config.author
        //- .author-info__description!= theme.aside.card_author.description || config.description
      .site-data.is-center
        a(href=url_for(config.archive_dir) + '/')
          .headline= _p('aside.articles') 
          .length-num= site.posts.length
        a(href=url_for(config.tag_dir) + '/' )
          .headline= _p('aside.tags')
          .length-num= site.tags.length
        a(href=url_for(config.category_dir) + '/')
          .headline= _p('aside.categories') 
          .length-num= site.categories.length

      //- begin follow_me按钮
      if theme.aside.card_author.button.enable
        a#card-info-btn.button--animated(href=theme.aside.card_author.button.link)
          i(class=theme.aside.card_author.button.icon)
          span=theme.aside.card_author.button.text
      //- end     
      //- //- begin 社交
      //- if(theme.social)
      //-   .menu-info-social-icons.is-center
      //-     !=fragment_cache('social', function(){return partial('includes/header/social')})
      //- //- end

      !=partial('includes/header/menu_item', {}, {cache: true})
