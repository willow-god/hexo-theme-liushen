#article-container
  .tag-Link
    background var(--liushen-card-bg)
    border-radius 12px !important
    display flex
    border var(--liushen-card-border)
    flex-direction column
    padding 0.5rem 1rem
    margin-top 1rem
    text-decoration none !important
    color var(--liushen-text)
    margin-bottom 10px
    transition background-color 0.3s ease-in-out , color 0.3s ease-in-out

    &:hover
      color white
      background-color var(--liushen-button-hover-bg)
      .tag-link-tips
        color white
        border-bottom 1px solid white
      .tag-link-bottom
        .tag-link-right
          .tag-link-sitename
            color rgb(210, 210, 210)

    .tag-link-tips
      color var(--liushen-text)
      border-bottom 1px solid var(--liushen-text)
      padding-bottom 4px
      font-size 0.6rem
      font-weight normal
      transition color 0.3s ease-in-out
      overflow hidden
      text-overflow ellipsis
      display -webkit-box
      -webkit-line-clamp 1
      -webkit-box-orient vertical
      transition border 0.3s ease-in-out !important

    .tag-link-bottom
      display flex
      margin-top 0.5rem
      align-items center
      justify-content space-around

      .tag-link-left
        width 60px
        min-width 60px
        height 60px
        background-size cover
        border-radius 25%

      .tag-link-right
        margin-left 1rem

        .tag-link-title
          font-size 1rem
          line-height 1.2
          // 不超过两行，超出部分显示省略号
          overflow hidden
          text-overflow ellipsis
          display -webkit-box
          -webkit-line-clamp 2
          -webkit-box-orient vertical

        .tag-link-sitename
          font-size 0.7rem
          color var(--liushen-secondtext)
          font-weight normal
          margin-top 4px
          transition color 0.3s  ease-in-out
          overflow: hidden
          text-overflow: ellipsis
          display: -webkit-box
          -webkit-line-clamp: 2
          -webkit-box-orient: vertical

        &:hover .tag-link-sitename
          color white

      i
        margin-left auto
