#owo-big 
    display: none;
    position: absolute;
    z-index: 9999;
    pointer-events: none;
    width: 150px;
    height: 150px;
    padding: 15px;
    background: var(--liushen-card-secondbg);
    border: var(--liushen-card-border);
    border-radius: 12px;
    box-shadow: var(--liushen-nav-shadow);
    opacity: 0;
    transition: opacity 0.2s ease;

    img 
        width: 100%;
        height: 100%;
        object-fit: fill;
