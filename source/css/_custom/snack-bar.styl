.float-box
  position fixed
  width 310px
  display flex
  flex-wrap wrap
  flex-direction column
  z-index 120

  // &.left
  //   left 20px
  //   align-items flex-start

  &.right
    right 5px
    align-items flex-end

  &.top
    top 64px

  // &.bottom
  //   bottom 35px

.float-win
  position relative
  overflow hidden
  width 100%
  background-color var(--liushen-nav-bg)
  border: var(--liushen-card-border)
  backdrop-filter: blur(10px)
  color var(--font-color)
  border-radius 12px
  box-shadow var(--liushen-nav-shadow)
  transition all 0.5s
  opacity 0
  margin-bottom 15px

  &.show
    opacity 1

  // &.left
  //   left -400px

  //   &.show
  //     left 0

  &.right
    right -400px

    &.show
      right 0

  @media screen and (max-width: 550px) and (min-width: 250px)
    width calc(65%)

  @media screen and (max-width: 250px)
    width calc(80%)

    & > .select > .descr
      color transparent

  & > i
    margin-left 10px

  & > .text
    position relative
    max-width 84%
    margin-left 8%
    text-align center
    margin-top 25px
    margin-bottom 20px
    word-break break-word
    word-wrap break-word
    // 下划线
    text-decoration underline dashed
    text-decoration-thickness 1px
    text-underline-offset 5px

    img
      max-width 90%
      object-fit contain
      border-radius 10px

  &.click
    & > .text
      margin-bottom 0

  & > .exit
    position absolute
    color var(--text-highlight-color)
    right 3px
    top 3px
    width 30px
    height 30px
    transition all 0.5s

    &:hover
      color deepskyblue
      transform rotate(90deg)

    i
      font-size 1em

  & > .select
    position relative
    text-align right
    margin-bottom 10px
    height 30px

    & > .descr
      position relative
      margin-top 0
      margin-right 6px
      display inline-block
      height 30px
      overflow hidden

      & > p
        position relative
        margin 0
        height 30px
        z-index 121
        transition all 1s

        &:not(.open)
          left 100px
          opacity 0

    & > .action
      display inline-block
      position relative
      float right
      z-index 121
      height 30px
      margin-right 10px
      background-color var(--liushen-button-bg)
      color var(--liushen-text)
      box-shadow var(--liushen-nav-shadow)
      padding 10px
      border-radius 7px
      transition all 0.5s

      & > .text
        display inline
        position relative
        bottom 4px
        font-weight bold

      & > i
        position relative
        bottom 4px
        margin-right 5px

      &:hover
        background-color var(--liushen-button-hover-bg)

        & + .descr > p
          left 0
          opacity 1

