/* 外链卡片 */
            .shuoshuo-external-link
                width: 100%
                height: 80px
                margin-top: 10px
                border-radius: 12px
                background-color: var(--liushen-card-secondbg)
                color: var(--liushen-card-text)
                border: var(--liushen-card-border)
                transition: background-color .3s ease-in-out
                &:hover
                    background-color: var(--liushen-button-hover-bg)

                .external-link
                    display: flex
                    color: var(--liushen-text) !important
                    width: 100%
                    height: 100%
                    &:hover
                        color: white !important
                        text-decoration: none !important

                    .external-link-left
                        width: 60px
                        height: 60px
                        margin: 10px
                        border-radius: 12px
                        background-size: cover
                        background-position: center

                    .external-link-right
                        display: flex
                        flex-direction: column
                        justify-content: center
                        width: calc(100% - 80px)
                        padding: 10px

                        .external-link-title
                            font-size: 1.0rem
                            font-weight: 800
                            white-space: nowrap
                            overflow: hidden
                            text-overflow: ellipsis

                        i
                            margin-left: 5px

.limit
  width: 100%
  text-align: center
  margin-top: 30px


@media (max-width: 900px)
  #talk .talk_item
    width: calc(50% - 5px)

  #talk .talk_item .talk_content .zone_imgbox
    --w: calc(33% - 5px)

  #talk .talk_item #post-comment
    margin: 0 3px

@media (max-width: 768px)
  .zone_imgbox
    gap: 6px
    --w: calc(50% - 3px)

  span.talk_date
    font-size: 14px

@media (max-width: 450px)
  #talk .talk_item
    width: 100%