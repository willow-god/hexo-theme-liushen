#sidebar
  #menu-mask
    position: fixed
    z-index: 102
    display: none
    width: 100%
    height: 100%
    background: alpha($dark-black, .3)

  #sidebar-menus
    position: fixed
    top: 0
    right: -($sidebar-width)
    z-index: 103
    overflow-x: hidden
    overflow-y: scroll
    // padding-left: 5px
    width: $sidebar-width
    height: 100%
    background: var(--sidebar-bg)
    transition: all .5s

    &.open
      transform: translate3d(-100%, 0, 0)

    & > .avatar-img
      margin: 20px auto

    .add-menu-container
      position: absolute
      top: 0
      left: 15px
      display: flex
      width: 50px
      padding: 10px 0 10px 0
      font-size: 1.2em
      flex-direction: column
      align-items: center
      background-color: var(--liushen-card-bg)
      border-radius: 0 0 30px 30px
      
    
    #card-info-btn
      display: block
      margin: 10px 20px 0 20px
      background-color: var(--btn-bg)
      color: var(--btn-color)
      text-align: center
      line-height: 2.4
      overflow: hidden
      border-radius: 0.625rem
      span
        padding-left: 10px
      &:hover
        background-color: var(--btn-hover-color)
    
    // .menu-info-social-icons
    //   margin: 0.5rem 0 0 0
    //   .social-icon
    //     display: inline
    //     color: var(--font-color)
    //     padding: 0 0.7rem 0 0.7rem
    //     font-size: 1.2rem
    //     transition: color .3s
    //     &:hover
    //       color: var(--btn-hover-color)

    .site-data
      padding: 0 10px
      margin-top: 0.5rem
    
    #sidebar-avatar
      margin-top: 2rem

      .author-info__name
        font-weight: 500
        font-size: 1.57em

    hr
      margin: 20px auto

    .menus_items
      margin: 20px
      padding: 15px
      background: var(--sidebar-menu-bg)
      box-shadow: 0 0 1px 1px rgba(7, 17, 27, .05)
      addBorderRadius(10)

      .site-page
        @extend .limit-one-line
        position: relative
        display: block
        margin: 4px 0
        padding: 2px 23px 2px 15px
        color: var(--font-color)
        font-size: 1.15em
        cursor: pointer
        transition: all .3s
        addBorderRadius(6)

        &:hover
          background: var(--text-bg-hover)
          padding-left: 20px
          color: var(--white)

        i:first-child
          width: 15%
          text-align: left

        &.group
          & > i:last-child
            position: absolute
            top: .6em
            right: 10px
            transition: transform .3s

          &.hide
            & > i:last-child
              transform: rotate(90deg)

            & + .menus_item_child
              display: none

      .menus_item_child
        margin: 0
        padding-left: 25px
        list-style: none